# Anthropic — Andes AI conversational assistant
# Obtén tu key en https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# Modelo a usar (default: claude-sonnet-4-6)
ANTHROPIC_MODEL=claude-sonnet-4-6
